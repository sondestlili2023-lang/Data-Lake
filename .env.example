# Telegram — alertes API /telegram/kpi-alert-check
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Ingestion : paris (Vélib Paris uniquement) | france (tous réseaux CityBikes FR)
INGEST_SCOPE=paris

# Flux GBFS officiel Vélib Métropole (Paris, temps réel)
VELIB_GBFS_BASE=https://velib-metropole-opendata.smovengo.cloud/opendata/Velib_Metropole

# JCDecaux — pas de Paris/Vélib ; activer seulement si INGEST_SCOPE=france
ENABLE_JCDECAUX=false
JCDECAUX_API_KEY=
JCDECAUX_CONTRACTS=

# CityBikes (secours Paris + mode france)
CITYBIKES_API_URL=https://api.citybik.es/v2

# OpenClaw — sync allowFrom + redémarrage auto du gateway
OPENCLAW_CONFIG_DIR=C:/Users/secre/.openclaw
OPENCLAW_AUTO_RESTART=true
OPENCLAW_WHATSAPP_SENDER=+33781744135
ALERT_SNOOZE_HOURS=6
